# ================================
# SERVER
# ================================
PORT=5000
NODE_ENV=development

# ================================
# DATABASE
# ================================
MONGO_URI=your_mongodb_connection_string_here

# ================================
# AUTHENTICATION
# ================================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# ================================
# DIALOG AXIATA API (SMS + Chatbot)
# ================================
DIALOG_API_KEY=your_dialog_axiata_api_key_here
DIALOG_API_URL=https://api.dialog.lk

# ================================
# FILE UPLOADS (for ticket attachments)
# ================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ================================
# NOTIFICATIONS
# ================================
PUSH_NOTIFICATION_KEY=your_push_notification_key_here

# ================================
# FRONTEND URLS (for CORS)
# ================================
WEB_CLIENT_URL=http://localhost:3000
MOBILE_CLIENT_URL=http://localhost:8081
